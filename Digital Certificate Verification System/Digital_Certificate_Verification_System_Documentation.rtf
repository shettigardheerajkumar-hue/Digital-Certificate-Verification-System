\b C.1 com.digitalcert.app.Main\b0\par
package com.digitalcert.app;\par
import com.digitalcert.dao.CertificateDao;\par
import com.digitalcert.dao.UserDao;\par
import com.digitalcert.dao.jdbc.CertificateDaoJdbcImpl;\par
import com.digitalcert.dao.jdbc.UserDaoJdbcImpl;\par
import com.digitalcert.service.CertificateService;\par
import com.digitalcert.service.UserService;\par
import com.digitalcert.ui.AuthMenu;\par
import com.digitalcert.ui.ConsoleMenu;\par
import com.digitalcert.util.DBConnectionUtil;\par
public class Main {\par
    public static void main(String[] args) {\par
        DBConnectionUtil dbConnectionUtil = new DBConnectionUtil();\par
        CertificateDao certificateDao = new CertificateDaoJdbcImpl(dbConnectionUtil);\par
        CertificateService certificateService = new CertificateService(certificateDao);\par
        UserDao userDao = new UserDaoJdbcImpl(dbConnectionUtil);\par
        UserService userService = new UserService(userDao);\par
        AuthMenu authMenu = new AuthMenu(userService);\par
        boolean authenticated = authMenu.start();\par
        if (!authenticated) {\par
            return;\par
        }\par
        ConsoleMenu consoleMenu = new ConsoleMenu(certificateService);\par
        consoleMenu.start();\par
    }\par
}\par
\par
\b C.2 com.digitalcert.ui.AuthMenu\b0\par
package com.digitalcert.ui;\par
import com.digitalcert.service.UserService;\par
import java.util.Scanner;\par
public class AuthMenu {\par
    private final UserService userService;\par
    private final Scanner scanner;\par
    public AuthMenu(UserService userService) {\par
        this.userService = userService;\par
        this.scanner = new Scanner(System.in);\par
    }\par
    public boolean start() {\par
        while (true) {\par
            printMenu();\par
            int choice = readInt("Enter your choice: ");\par
            switch (choice) {\par
                case 1 -> {\par
                    if (login()) {\par
                        return true;\par
                    }\par
                }\par
                case 2 -> register();\par
                case 3 -> {\par
                    System.out.println("Exiting application. Goodbye!");\par
                    return false;\par
                }\par
                default -> System.out.println("Invalid choice. Please try again.");\par
            }\par
        }\par
    }\par
    private void printMenu() {\par
        System.out.println("\\n=== Digital Certificate Verification System ===");\par
        System.out.println("1. Login");\par
        System.out.println("2. Register");\par
        System.out.println("3. Exit");\par
    }\par
    private boolean login() {\par
        System.out.println("\\n-- Login --");\par
        System.out.print("Username: ");\par
        String username = scanner.nextLine();\par
        System.out.print("Password: ");\par
        String password = scanner.nextLine();\par
        boolean authenticated = userService.authenticate(username, password);\par
        if (authenticated) {\par
            System.out.println("Login successful. Welcome, " + username + "!");\par
            return true;\par
        } else {\par
            System.out.println("Invalid username or password.");\par
            return false;\par
        }\par
    }\par
    private void register() {\par
        System.out.println("\\n-- Register --");\par
        System.out.print("Choose a username: ");\par
        String username = scanner.nextLine();\par
        System.out.print("Choose a password: ");\par
        String password = scanner.nextLine();\par
        try {\par
            userService.register(username, password);\par
            System.out.println("Registration successful. You can now log in.");\par
        } catch (RuntimeException ex) {\par
            System.out.println("Registration failed: " + ex.getMessage());\par
        }\par
    }\par
    private int readInt(String prompt) {\par
        while (true) {\par
            System.out.print(prompt);\par
            String line = scanner.nextLine();\par
            try {\par
                return Integer.parseInt(line.trim());\par
            } catch (NumberFormatException ex) {\par
                System.out.println("Invalid number. Please try again.");\par
            }\par
        }\par
    }\par
}\par
